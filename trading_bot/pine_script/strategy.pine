// ============================================================
// Titan Markets LLC — MACD + Bollinger Bands Session Strategy
// ============================================================
// Mirrors the Python bot's signal logic so you can visualise
// and verify entries/exits directly on TradingView charts.
//
// Requires TradingView Pro or above to use webhook alerts.
//
// HOW TO USE
// ----------
// 1. Open TradingView → Pine Script Editor → paste this code
// 2. Add to chart on your preferred symbol & timeframe (5m recommended)
// 3. Go to Alerts → Create Alert → select this script
// 4. Set alert condition to "Order fills only" or "alert() function calls only"
// 5. Set Webhook URL to: http://<your-server-ip>:5001/webhook
// 6. Copy the JSON message template below into the alert message box
//
// Alert message template (copy exactly):
// {
//   "secret": "YOUR_WEBHOOK_SECRET_HERE",
//   "symbol": "{{ticker}}",
//   "action": "{{strategy.order.action}}",
//   "price":  {{close}},
//   "sl":     {{strategy.position_avg_price}},
//   "tp":     {{strategy.position_avg_price}}
// }
// ============================================================

//@version=5
strategy(
    title             = "TM LLC — MACD + BB Session Bot",
    overlay           = true,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 1,
    initial_capital   = 100000,
    currency          = currency.USD,
    commission_type   = strategy.commission.percent,
    commission_value  = 0.01
)

// ── Inputs ────────────────────────────────────────────────────────────────────

// MACD
macd_fast   = input.int(12,  "MACD Fast",   minval=1)
macd_slow   = input.int(26,  "MACD Slow",   minval=1)
macd_signal = input.int(9,   "MACD Signal", minval=1)

// Bollinger Bands
bb_len      = input.int(20,  "BB Length",   minval=1)
bb_mult     = input.float(2.0, "BB Std Dev", minval=0.1, step=0.1)

// ATR for stop-loss buffer
atr_len     = input.int(14,  "ATR Length",  minval=1)
sl_atr_buf  = input.float(0.5, "SL ATR Buffer", minval=0.0, step=0.1)
rr          = input.float(2.5, "Take Profit R:R", minval=0.5, step=0.5)

// Session filter (UTC+0)
london_open  = input.session("0800-1100", "London Session (UTC)",  group="Sessions")
ny_open      = input.session("1330-1600", "New York Session (UTC)", group="Sessions")

// ── Indicator calculations ─────────────────────────────────────────────────────

[macd_line, signal_line, hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)

bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

atr_val  = ta.atr(atr_len)

// ── Session filter ─────────────────────────────────────────────────────────────

in_london = not na(time(timeframe.period, london_open, "UTC"))
in_ny     = not na(time(timeframe.period, ny_open,     "UTC"))
in_session = in_london or in_ny

// ── Entry conditions ───────────────────────────────────────────────────────────

macd_cross_up   = ta.crossover(macd_line, signal_line)
macd_cross_down = ta.crossunder(macd_line, signal_line)

long_condition  = macd_cross_up   and close <= bb_lower and in_session
short_condition = macd_cross_down and close >= bb_upper and in_session

// ── SL / TP calculation ────────────────────────────────────────────────────────

long_sl  = bb_lower - sl_atr_buf * atr_val
long_tp  = close    + (close - long_sl) * rr

short_sl = bb_upper + sl_atr_buf * atr_val
short_tp = close    - (short_sl - close) * rr

// ── Strategy orders ────────────────────────────────────────────────────────────

if long_condition
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long",
                  stop  = long_sl,
                  limit = long_tp,
                  comment = "SL/TP")

if short_condition
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short",
                  stop  = short_sl,
                  limit = short_tp,
                  comment = "SL/TP")

// Time-based exit: close 30 min before session end
london_close_buffer = not na(time(timeframe.period, "1030-1100", "UTC"))
ny_close_buffer     = not na(time(timeframe.period, "1530-1600", "UTC"))
time_exit = london_close_buffer or ny_close_buffer

if time_exit and strategy.position_size != 0
    strategy.close_all(comment = "Time Exit")

// ── Webhook alerts ─────────────────────────────────────────────────────────────
// These fire the actual alerts that your webhook server receives.

if long_condition
    alert('{"secret":"YOUR_SECRET","symbol":"' + syminfo.ticker +
          '","action":"BUY","price":' + str.tostring(close, "#.#####") +
          ',"sl":'  + str.tostring(long_sl,  "#.#####") +
          ',"tp":'  + str.tostring(long_tp,  "#.#####") + '}',
          alert.freq_once_per_bar_close)

if short_condition
    alert('{"secret":"YOUR_SECRET","symbol":"' + syminfo.ticker +
          '","action":"SELL","price":' + str.tostring(close, "#.#####") +
          ',"sl":'  + str.tostring(short_sl,  "#.#####") +
          ',"tp":'  + str.tostring(short_tp,  "#.#####") + '}',
          alert.freq_once_per_bar_close)

if time_exit and strategy.position_size != 0
    alert('{"secret":"YOUR_SECRET","symbol":"' + syminfo.ticker +
          '","action":"CLOSE","price":' + str.tostring(close, "#.#####") + '}',
          alert.freq_once_per_bar_close)

// ── Visuals ────────────────────────────────────────────────────────────────────

plot(bb_upper, "BB Upper", color=color.new(color.blue,  70), linewidth=1)
plot(bb_basis, "BB Mid",   color=color.new(color.gray,  60), linewidth=1)
plot(bb_lower, "BB Lower", color=color.new(color.blue,  70), linewidth=1)

bgcolor(
    in_session ? color.new(color.green, 95) : na,
    title="Active Session"
)

plotshape(long_condition,  title="Long Entry",  style=shape.triangleup,
          location=location.belowbar, color=color.lime,  size=size.small)
plotshape(short_condition, title="Short Entry", style=shape.triangledown,
          location=location.abovebar, color=color.red,   size=size.small)

// ── Info table ─────────────────────────────────────────────────────────────────

var table info = table.new(position.top_right, 2, 5,
                           bgcolor=color.new(color.black, 70),
                           border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "TM LLC Bot",  text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, "MACD + BB",   text_color=color.aqua,  text_size=size.small)
    table.cell(info, 0, 1, "Session",     text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, in_session ? "ACTIVE" : "CLOSED",
               text_color=in_session ? color.lime : color.red, text_size=size.small)
    table.cell(info, 0, 2, "MACD",        text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, macd_line > signal_line ? "BULL" : "BEAR",
               text_color=macd_line > signal_line ? color.lime : color.red,
               text_size=size.small)
    table.cell(info, 0, 3, "BB Position", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3,
               close >= bb_upper ? "UPPER" : close <= bb_lower ? "LOWER" : "MID",
               text_color=color.yellow, text_size=size.small)
    table.cell(info, 0, 4, "R:R",         text_color=color.white, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(rr, "#.#") + ":1",
               text_color=color.orange, text_size=size.small)
